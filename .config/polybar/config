[colors]
background      = #1e1f21
foreground      = f8f8f2
bordeer         = #0c7ed6
red             = #f24649

[bar/general]
enable-ipc = true
border-size = 0
border-color = #{colors.border}
padding-right = 2
radius = 6
background = ${colors.background}
foreground = ${colors.foreground}

font-0 = Ubuntu-Medium:size=16
font-1 = icomoon:style=Regular:size=16
font-2 = FontAwesome:size=16
;font-3 = Font Awesome 5 Free:size=10;1
separator = "          "
dim-value = .90
override-redirect = true

tray-position = none
pseudo-transparency = true


[bar/mybar]
inherits = bar/general
wm-restack = i3
height = 30
width = 3740
offset-x = 50
offset-y = 10
modules-left = i3 
modules-center = spotify previous playpause next
modules-right = memory cpu pulseaudio rss datetime menu-apps

[module/datetime]
type = internal/date
interval = 1.0
date = "%m/%d/%Y"
time = "%H:%M"
label = "%{F0d9adb}%date%    |    %time%%{F-}"

[module/pulseaudio]
type = internal/pulseaudio
sink = alsa_output.pci-0000_1200.3.analog-stereo
use-ui-max = true
interval = 5
format-volume = <ramp-volume> <label-volume>
label-muted =   muted
label-muted-foreground = ${colors.red}
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 
click-middle = pavucontrol

[module/cpu]
type = internal/cpu
interval = 0.5
format = <label> 
label = CPU  %percentage%%

[module/memory]
type = internal/memory
interval = 3
format = <label>
label = RAM  %gb_used%/%gb_total%

[module/i3]
type = internal/i3
enabe-click = true
format = <label-state> 
label-focused = %index%
label-focused-background = #0c7ed6
label-focused-padding = 2
label-unfocused = %index%
label-unfocused-padding = 2
label-urgent = %index%
label-urgent-background = ${colors.red}
label-urgent-padding = 2

[module/menu-apps]
type = custom/menu
expand-right = false
menu-0-0 = "%{F#f00} Shutdown "    
menu-0-0-exec = shutdown
menu-0-1 = " Logout " 
menu-0-1-exec = pkill -KILL -u $USER && logout      
menu-0-2 = " Reboot"
menu-0-2-exec = reboot      

label-open ="%{F#f00} %{F-}"
label-close =" %{F-}"
label-separator =  | 

[module/rss]
type = custom/text
click-left = gfeeds
content = %{F#ffff00}%{F-}


; https://github.com/mihirlad55/polybar-spotify-module must be installed

[module/previous]
type = custom/ipc
format-font = 2
; Default
hook-0 = echo ""
; When spotify active
hook-1 = echo ""
click-left = "spotifyctl -q previous"


[module/next]
type = custom/ipc
format-font = 2
; Default
hook-0 = echo ""
; When spotify active
hook-1 = echo ""
click-left = "spotifyctl -q next"


[module/playpause]
type = custom/ipc
format-font = 2
; Default
hook-0 = echo ""
; Playing
hook-1 = echo ""
; Paused
hook-2 = echo ""
click-left = "spotifyctl -q playpause"


[module/spotify]
type = custom/ipc
; Default
hook-0 = echo ""
; Playing/paused show song name and artist
hook-1 = spotifyctl -q status --format '%{F#4fdb36} %{F-}%{F#f41317} %artist%: %title% %{F-}' --max-length 55 --max-title-length 30 --max-artist-length 25 --trunc '...'
