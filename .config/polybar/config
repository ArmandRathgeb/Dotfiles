[bar/general]
enable-ipc = true
background = #1e1f21
foreground = #f8f8f2
border-size = 0
border-color = #0c7ed6
padding-right = 2

radius-bottom = 6

font-0 = Ubuntu-Medium:size=16
font-1 = Font Awesome 5 Free:size=10;1
font-2 = icomoon:style=Regular:size=16
font-3 = FontAwesome:size=16
font-4 = octicons:style=Medium:size=16


separator = "          "

dim-value = 1

tray-position = none


[bar/mybar]
inherits = bar/general
wm-restack = i3
height = 30
width = 3840
offset-x = 50
offset-y = 30
modules-left = i3 
modules-center = spotify previous playpause next
modules-right = memory cpu pulseaudio datetime

[settings]
pseudo-transparency = true

[module/datetime]
type = internal/date
interval = 1.0
date = "%m/%d/%Y"
time = "%H:%M"
label = "%{F0d9adb}%date%    |    %time%%{F-}"

[module/pulseaudio]
type = internal/pulseaudio
sink = alsa_output.pci-0000_1200.3.analog-stereo
use-ui-max = true
interval = 5
format-volume = <ramp-volume> <label-volume>
label-muted =   muted
label-muted-foreground = #f24649
ramp-volume-0 = 
ramp-volume-1 = 
ramp-volume-2 = 
click-middle = pavucontrol

[module/cpu]
type = internal/cpu
interval = 0.5
format = <label> 
label = CPU  %percentage%%

[module/memory]
type = internal/memory
interval = 3
format = <label>
label = RAM  %gb_used%/%gb_total%

[module/i3]
type = internal/i3
enabe-click = true
format = <label-state> 
label-focused = %index%
label-focused-background = #0c7ed6
label-focused-padding = 2
label-unfocused = %index%
label-unfocused-padding = 2
label-urgent = %index%
label-urgent-background = #f40410
label-urgent-padding = 2

; https://github.com/mihirlad55/polybar-spotify-module must be installed

[module/previous]
type = custom/ipc
format-font = 2
; Default
hook-0 = echo ""
; When spotify active
hook-1 = echo ""
click-left = "spotifyctl -q previous"


[module/next]
type = custom/ipc
format-font = 2
; Default
hook-0 = echo ""
; When spotify active
hook-1 = echo ""
click-left = "spotifyctl -q next"


[module/playpause]
type = custom/ipc
format-font = 2
; Default
hook-0 = echo ""
; Playing
hook-1 = echo ""
; Paused
hook-2 = echo ""
click-left = "spotifyctl -q playpause"


[module/spotify]
type = custom/ipc
; Default
hook-0 = echo ""
; Playing/paused show song name and artist
hook-1 = spotifyctl -q status --format '%{F#4fdb36} %{F-}%{F#f41317} %artist%: %title% %{F-}' --max-length 55 --max-title-length 30 --max-artist-length 25 --trunc '...'
